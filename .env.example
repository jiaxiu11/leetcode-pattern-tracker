# Copy this file to .env and fill in your values

POSTGRES_DB=lc_tracker
POSTGRES_USER=lc_user
POSTGRES_PASSWORD=your_password_here

# To rotate secrets:
# 1. Update values above in .env
# 2. export $(cat .env | xargs) && envsubst < k8s/db/secret.yaml | kubeseal --format yaml > k8s/db/sealed-secret.yaml
# 3. git add k8s/db/sealed-secret.yaml && git commit && git push
# ArgoCD will apply the updated secret automatically
